// ThemeColors struct - all color properties for dynamic theming
export struct ThemeColors {
    // Base colors
    bg-primary: color,
    bg-secondary: color,
    bg-tertiary: color,
    bg-hover: color,
    bg-selected: color,

    // Border colors
    border-subtle: color,
    border-normal: color,

    // Text colors
    text-primary: color,
    text-secondary: color,
    text-muted: color,

    // Diff colors
    diff-add-bg: color,
    diff-add-text: color,
    diff-add-gutter: color,
    diff-remove-bg: color,
    diff-remove-text: color,
    diff-remove-gutter: color,
    diff-context-bg: color,
    diff-hunk-bg: color,
    diff-hunk-text: color,

    // Accent colors
    accent-primary: color,
    accent-secondary: color,

    // Status colors
    status-added: color,
    status-modified: color,
    status-deleted: color,

    // Comment colors
    comment-bg: color,
    comment-border: color,
    comment-author: color,
    comment-body: color,
    comment-timestamp: color,
}

// Theme presets as pure functions
export global ThemePresets {
    // Dark theme - industrial dark with refined accents (original)
    pure public function dark() -> ThemeColors {
        return {
            // Base colors
            bg-primary: #1a1b1e,
            bg-secondary: #212225,
            bg-tertiary: #2a2b2f,
            bg-hover: #323338,
            bg-selected: #3a3b40,

            // Border colors
            border-subtle: #2e2f33,
            border-normal: #3a3b40,

            // Text colors
            text-primary: #e4e4e7,
            text-secondary: #a0a0a6,
            text-muted: #6b6b73,

            // Diff colors - muted for reduced eye strain
            diff-add-bg: #1a2e1a,
            diff-add-text: #7ec77e,
            diff-add-gutter: #2d4a2d,
            diff-remove-bg: #2e1a1a,
            diff-remove-text: #e07070,
            diff-remove-gutter: #4a2d2d,
            diff-context-bg: #1a1b1e,
            diff-hunk-bg: #252830,
            diff-hunk-text: #7090b0,

            // Accent colors
            accent-primary: #58a6ff,
            accent-secondary: #8b949e,

            // Status colors
            status-added: #3fb950,
            status-modified: #d29922,
            status-deleted: #f85149,

            // Comment colors
            comment-bg: #2d333b,
            comment-border: #444c56,
            comment-author: #58a6ff,
            comment-body: #e4e4e7,
            comment-timestamp: #6b6b73,
        };
    }

    // Light theme - clean and readable
    pure public function light() -> ThemeColors {
        return {
            // Base colors
            bg-primary: #ffffff,
            bg-secondary: #f6f8fa,
            bg-tertiary: #eaeef2,
            bg-hover: #d8dee4,
            bg-selected: #dbe5ed,

            // Border colors
            border-subtle: #d0d7de,
            border-normal: #afb8c1,

            // Text colors
            text-primary: #1f2328,
            text-secondary: #57606a,
            text-muted: #8c959f,

            // Diff colors - GitHub-style light theme
            diff-add-bg: #e6ffec,
            diff-add-text: #1a7f37,
            diff-add-gutter: #ccffd8,
            diff-remove-bg: #ffebe9,
            diff-remove-text: #cf222e,
            diff-remove-gutter: #ffd7d5,
            diff-context-bg: #ffffff,
            diff-hunk-bg: #f0f6fc,
            diff-hunk-text: #0550ae,

            // Accent colors
            accent-primary: #0969da,
            accent-secondary: #57606a,

            // Status colors
            status-added: #1a7f37,
            status-modified: #9a6700,
            status-deleted: #cf222e,

            // Comment colors
            comment-bg: #f6f8fa,
            comment-border: #d0d7de,
            comment-author: #0969da,
            comment-body: #1f2328,
            comment-timestamp: #8c959f,
        };
    }

    // Solarized Dark theme
    // Official palette: base03=#002b36, base02=#073642, base01=#586e75, base00=#657b83
    //                   base0=#839496, base1=#93a1a1, base2=#eee8d5, base3=#fdf6e3
    // Accents: yellow=#b58900, orange=#cb4b16, red=#dc322f, magenta=#d33682
    //          violet=#6c71c4, blue=#268bd2, cyan=#2aa198, green=#859900
    pure public function solarized-dark() -> ThemeColors {
        return {
            // Base colors (dark mode uses base03/base02 for backgrounds)
            bg-primary: #002b36,    // base03 - main background
            bg-secondary: #073642,  // base02 - highlighted background
            bg-tertiary: #073642,   // base02 - (Solarized has limited bg options)
            bg-hover: #073642,      // base02
            bg-selected: #073642,   // base02

            // Border colors (using base01 and base00)
            border-subtle: #586e75, // base01
            border-normal: #657b83, // base00

            // Text colors (dark mode uses base0/base1 for text)
            text-primary: #839496,  // base0 - body text
            text-secondary: #93a1a1, // base1 - emphasized/secondary
            text-muted: #586e75,    // base01 - comments/muted

            // Diff colors (green/red tinted backgrounds blended with base03)
            diff-add-bg: #073626,       // base03 + green tint
            diff-add-text: #859900,     // green
            diff-add-gutter: #0a4030,   // slightly stronger green tint for gutter
            diff-remove-bg: #30262a,    // base03 + red tint
            diff-remove-text: #dc322f,  // red
            diff-remove-gutter: #3a2830, // slightly stronger red tint for gutter
            diff-context-bg: #002b36,   // base03
            diff-hunk-bg: #073642,      // base02
            diff-hunk-text: #268bd2,    // blue

            // Accent colors (Solarized blue/cyan)
            accent-primary: #268bd2,  // blue
            accent-secondary: #2aa198, // cyan

            // Status colors
            status-added: #859900,    // green
            status-modified: #b58900, // yellow
            status-deleted: #dc322f,  // red

            // Comment colors
            comment-bg: #073642,      // base02
            comment-border: #586e75,  // base01
            comment-author: #268bd2,  // blue
            comment-body: #839496,    // base0
            comment-timestamp: #586e75, // base01
        };
    }

    // Solarized Light theme (doom-solarized-light inspired)
    // Based on doom-solarized-light palette from Emacs:
    //   bg=#FDF6E3, fg=#556b72, bg-alt=#EEE8D5, fg-alt=#7B8787
    //   base0-8: #FFFBF0..#626C6C gradients
    // Accents: yellow=#b58900, orange=#cb4b16, red=#dc322f, magenta=#d33682
    //          violet=#6c71c4, blue=#268bd2, cyan=#2aa198, green=#859900
    pure public function solarized-light() -> ThemeColors {
        return {
            // Base colors (doom-solarized-light palette)
            bg-primary: #FDF6E3,    // bg - main background
            bg-secondary: #EEE8D5,  // bg-alt - alternate background
            bg-tertiary: #F2E6CE,   // base3 - tertiary background
            bg-hover: #E1DBCD,      // base4 - hover state
            bg-selected: #D6D6D6,   // base5 - selected state

            // Border colors (using muted tones from base spectrum)
            border-subtle: #E1DBCD, // base4 - subtle borders
            border-normal: #96A7A9, // base6 - normal borders

            // Text colors (doom-solarized-light values)
            text-primary: #556b72,  // fg - body text
            text-secondary: #788484, // base7 - secondary text
            text-muted: #96A7A9,    // base6 - muted/comments

            // Diff colors (green/red tinted backgrounds blended with bg)
            diff-add-bg: #e4f0d0,       // bg + green tint
            diff-add-text: #859900,     // green
            diff-add-gutter: #d8e8c0,   // slightly stronger green tint for gutter
            diff-remove-bg: #fce8e4,    // bg + red tint
            diff-remove-text: #dc322f,  // red
            diff-remove-gutter: #f8d8d4, // slightly stronger red tint for gutter
            diff-context-bg: #FDF6E3,   // bg
            diff-hunk-bg: #EEE8D5,      // bg-alt
            diff-hunk-text: #268bd2,    // blue

            // Accent colors (doom-solarized-light uses blue/cyan)
            accent-primary: #268bd2,   // blue
            accent-secondary: #2aa198, // cyan

            // Status colors (semantic mappings from doom)
            status-added: #859900,     // green (success)
            status-modified: #b58900,  // yellow (warning)
            status-deleted: #dc322f,   // red (error)

            // Comment colors
            comment-bg: #EEE8D5,       // bg-alt
            comment-border: #96A7A9,   // base6
            comment-author: #268bd2,   // blue
            comment-body: #556b72,     // fg
            comment-timestamp: #7B8787, // fg-alt
        };
    }
}

